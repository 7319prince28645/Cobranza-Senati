{
  "name": "cobranza-senati",
  "productName": "Cobranza SENATI",
  "version": "1.0.0",
  "description": "Sistema de Cobranza y Comandos SENATI",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win portable"
  },
  "author": "SENATI",
  "license": "ISC",
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "express": "^4.18.2",
    "cors": "^2.8.5"
  },
  "build": {
    "appId": "com.senati.cobranza",
    "productName": "Cobranza SENATI",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js"
    ],
    "win": {
      "target": "portable",
      "icon": "icon.ico"
    },
    "portable": {
      "artifactName": "${productName}.exe"
    },
    "extraResources": [
      {
        "from": "../automatizacion",
        "to": "backend",
        "filter": ["**/*", "!.git", "!test*", "!*.spec.js"]
      },
      {
        "from": "../Senati-comandos/dist",
        "to": "frontend",
        "filter": ["**/*"]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "**/backend/**"
    ]
  }
}
